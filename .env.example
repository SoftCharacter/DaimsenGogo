# Generic OpenAI-compatible large model configuration.
# Fill these in your local .env file. Do not commit .env.
LLM_PROVIDER_NAME=
LLM_BASE_URL=https://your-provider.example.com/v1
LLM_API_KEY=
LLM_MODEL=

# Required for DG analysis: Tavily web_search evidence.
WEB_SEARCH_ENABLED=true
TAVILY_API_KEY=

# Optional: override allowed frontend origins for FastAPI CORS.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
